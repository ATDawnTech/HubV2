# Local development environment variables — copy to .env and fill in values.
# .env is gitignored and must never be committed.
# For AWS environments, secrets are injected from SSM — do not use this file in CI/CD.

# Database — local Docker Postgres
DATABASE_URL=postgresql://adthub_admin:localpassword@localhost:5432/adthub_local

# Auth — required, no default in code. Use any string locally; SSM in deployed envs.
JWT_SECRET=local-dev-signing-key-not-for-production
# Set to true in local dev to skip permission enforcement. Never true in production.
SKIP_PERMISSION_CHECKS=true

# SAML — use test values locally; real values live in SSM for deployed environments
SAML_SP_ENTITY_ID=adthub-local
SAML_CALLBACK_URL=http://localhost:3001/v1/auth/callback
SAML_IDP_SSO_URL=
SAML_IDP_CERT=

# App
ENVIRONMENT=local
ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
