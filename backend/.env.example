# .env.example for HubV2 backend
# Copy to .env and fill in values before running locally.
# Never commit .env — it is in .gitignore.

# Database — local PostgreSQL via Docker Compose
DATABASE_URL=
TEST_DATABASE_URL=

# JWT — use any string for local development, clearly not for production
JWT_SECRET=

# Application — ENVIRONMENT is set by docker-compose (local) and Terraform (dev/prod).
# You do not need to set it here.
DEBUG=true
LOG_LEVEL=DEBUG
SKIP_PERMISSION_CHECKS=false
ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Microsoft Entra SSO — leave blank to disable SSO in local dev.
# Get these values from the Entra app registration in the Azure portal.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:3001/v1/auth/callback

# Entra security group Object IDs — map groups to app roles on login.
# Find these in Azure Portal → Entra ID → Groups → <group> → Object ID.
AZURE_SYSADMIN_GROUP_ID=
AZURE_DEVELOPER_GROUP_ID=
AZURE_USER_GROUP_ID=
